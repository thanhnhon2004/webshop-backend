# ===== SERVER CONFIGURATION =====
# Port mà server chạy
PORT=2004

# Node environment
NODE_ENV=development

# ===== DATABASE CONFIGURATION =====
# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/be_database
# Production: mongodb+srv://username:password@cluster.mongodb.net/database_name
MONGO_URI=mongodb://127.0.0.1:27017/be_database

# ===== JWT TOKEN CONFIGURATION =====
# Access token secret (15 phút)
# Dùng để sign access token
# ⚠️ IMPORTANT: Change this in production!
# Generate: openssl rand -base64 32
JWT_SECRET=your-access-token-secret-key-min-32-characters-change-in-production

# Refresh token secret (7 ngày)
# Dùng để sign refresh token
# ⚠️ IMPORTANT: Change this in production!
# Generate: openssl rand -base64 32
JWT_REFRESH_SECRET=your-refresh-token-secret-key-min-32-characters-change-in-production

# ===== CORS CONFIGURATION =====
# Frontend URL (cho phép cross-origin requests)
# Development: http://localhost:4200
# Production: https://yourdomain.com
FE_URL=http://localhost:4200

# ===== FILE UPLOAD CONFIGURATION =====
# Base URL cho ảnh được serve
# Development: http://localhost:2004
# Production: https://yourdomain.com or https://cdn.yourdomain.com
BASE_URL=http://localhost:2004

# Max file size for uploads (in bytes)
# Default: 5242880 (5MB)
MAX_FILE_SIZE=5242880

# ===== RATE LIMITING CONFIGURATION =====
# Rate limit window (in milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP
RATE_LIMIT_MAX_REQUESTS=100

# ===== EMAIL CONFIGURATION (Optional - for future use) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourdomain.com

# ===== LOGGING CONFIGURATION =====
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ===== PAYMENT GATEWAY (Optional - for future use) =====
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLIC_KEY=pk_test_...
