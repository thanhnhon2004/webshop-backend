{
  "info": {
    "_postman_id": "6c6f7265-6c61-4973-9f61-504f6f73746d",
    "name": "LOL Figures API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for LOL Figures Store backend"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"}
            ],
            "url": {"raw": "{{base_url}}/api/users/register", "host": ["{{base_url}}"], "path": ["api","users","register"]},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"0123456789\"\n}"}
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"}
            ],
            "url": {"raw": "{{base_url}}/api/users/login", "host": ["{{base_url}}"], "path": ["api","users","login"]},
            "body": {"mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"Admin@123456\"\n}"}
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products (with search/pagination)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/products?search=ahri&page=1&limit=12&sort=popular",
              "host": ["{{base_url}}"], "path": ["api","products"],
              "query": [
                {"key":"search","value":"ahri"},
                {"key":"page","value":"1"},
                {"key":"limit","value":"12"},
                {"key":"sort","value":"popular"}
              ]
            }
          }
        },
        {
          "name": "Create Product (admin)",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"},
              {"key":"Authorization","value":"Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/products", "host": ["{{base_url}}"], "path": ["api","products"]},
            "body": {"mode": "raw", "raw": "{\n  \"name\": \"Ahri Figurine\",\n  \"description\": \"Beautiful Ahri\",\n  \"price\": 299000,\n  \"image\": \"https://example.com/ahri.jpg\",\n  \"images\": [],\n  \"stock\": 100,\n  \"category\": \"Figurine\",\n  \"champion\": \"Ahri\"\n}"}
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "User Orders (date range)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{token}}"}],
            "url": {
              "raw": "{{base_url}}/api/orders/{{userId}}?startDate=2026-01-01&endDate=2026-01-31",
              "host": ["{{base_url}}"], "path": ["api","orders","{{userId}}"],
              "query": [
                {"key":"startDate","value":"2026-01-01"},
                {"key":"endDate","value":"2026-01-31"}
              ]
            }
          }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"},
              {"key":"Authorization","value":"Bearer {{token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/orders/{{userId}}/checkout", "host": ["{{base_url}}"], "path": ["api","orders","{{userId}}","checkout"]},
            "body": {"mode": "raw", "raw": "{\n  \"paymentMethod\": \"credit_card\",\n  \"shippingAddress\": {\n    \"fullName\": \"Test User\",\n    \"phone\": \"0123456789\",\n    \"email\": \"test@example.com\",\n    \"address\": \"123 Street\",\n    \"district\": \"Hoan Kiem\",\n    \"province\": \"Ha Noi\"\n  },\n  \"voucherCode\": \"WELCOME10\",\n  \"weight\": 2\n}"}
          }
        },
        {
          "name": "Admin Orders (pagination + filter)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{admin_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/orders/admin?status=pending&startDate=2026-01-01&endDate=2026-01-15&page=1&limit=20",
              "host": ["{{base_url}}"], "path": ["api","orders","admin"],
              "query": [
                {"key":"status","value":"pending"},
                {"key":"startDate","value":"2026-01-01"},
                {"key":"endDate","value":"2026-01-15"},
                {"key":"page","value":"1"},
                {"key":"limit","value":"20"}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users (admin)",
      "item": [
        {
          "name": "List customers (pagination)",
          "request": {
            "method": "GET",
            "header": [{"key":"Authorization","value":"Bearer {{admin_token}}"}],
            "url": {
              "raw": "{{base_url}}/api/users?page=1&limit=20",
              "host": ["{{base_url}}"], "path": ["api","users"],
              "query": [
                {"key":"page","value":"1"},
                {"key":"limit","value":"20"}
              ]
            }
          }
        },
        {
          "name": "Lock account (admin)",
          "request": {
            "method": "PUT",
            "header": [
              {"key":"Content-Type","value":"application/json"},
              {"key":"Authorization","value":"Bearer {{admin_token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/users/{{userId}}/lock", "host": ["{{base_url}}"], "path": ["api","users","{{userId}}","lock"]},
            "body": {"mode": "raw", "raw": "{\n  \"isLocked\": true\n}"}
          }
        }
      ]
    },
    {
      "name": "Vouchers",
      "item": [
        {
          "name": "Validate voucher",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw": "{{base_url}}/api/vouchers/validate-voucher", "host": ["{{base_url}}"], "path": ["api","vouchers","validate-voucher"]},
            "body": {"mode": "raw", "raw": "{\n  \"code\": \"WELCOME10\",\n  \"orderAmount\": 500000\n}"}
          }
        },
        {
          "name": "Create voucher (admin)",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"},
              {"key":"Authorization","value":"Bearer {{admin_token}}"}
            ],
            "url": {"raw": "{{base_url}}/api/vouchers/admin/vouchers", "host": ["{{base_url}}"], "path": ["api","vouchers","admin","vouchers"]},
            "body": {"mode": "raw", "raw": "{\n  \"code\": \"SALE50\",\n  \"discountType\": \"fixed\",\n  \"discountValue\": 50000,\n  \"minOrderAmount\": 500000,\n  \"expiryDate\": \"2026-12-31T23:59:59.000Z\"\n}"}
          }
        }
      ]
    },
    {
      "name": "Shipping",
      "item": [
        {
          "name": "Calculate shipping",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "url": {"raw": "{{base_url}}/api/shipping/calculate-shipping", "host": ["{{base_url}}"], "path": ["api","shipping","calculate-shipping"]},
            "body": {"mode": "raw", "raw": "{\n  \"province\": \"Hà Nội\",\n  \"district\": \"Hoàn Kiếm\",\n  \"weight\": 2\n}"}
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {"type": "text/javascript", "exec": []}
    },
    {
      "listen": "test",
      "script": {"type": "text/javascript", "exec": []}
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://localhost:2004" },
    { "key": "token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "userId", "value": "" }
  ]
}
